{
  "name": "ai-employee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/gateway/server.ts",
    "start": "node dist/gateway/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "setup": "tsx scripts/setup.ts",
    "trigger-task": "tsx scripts/trigger-task.ts",
    "register-project": "tsx scripts/register-project.ts",
    "dev:start": "tsx scripts/dev-start.ts",
    "verify:e2e": "tsx scripts/verify-e2e.ts",
    "fly:setup": "tsx scripts/fly-setup.ts",
    "fly:image": "docker buildx build --platform linux/amd64 --tag registry.fly.io/ai-employee-workers:latest --push .",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.3",
    "@prisma/client": "^6.0.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "express": "^5.2.1",
    "inngest": "^4.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@inngest/test": "^1.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "zx": "^8.8.5"
  }
}
