{
  "name": "ai-employee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "dashboard:build": "cd dashboard && pnpm install && pnpm build",
    "dev": "tsx scripts/dev.ts",
    "start": "node dist/gateway/server.js",
    "lint": "eslint .",
    "lint:unused": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "test:file": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:dashboard": "cd dashboard && pnpm exec vitest run --config vitest.config.ts",
    "setup": "tsx scripts/setup.ts",
    "trigger-task": "tsx scripts/trigger-task.ts",
    "stress-test": "tsx scripts/stress-test.ts",
    "register-project": "tsx scripts/register-project.ts",
    "register-dev-slack": "tsx scripts/register-dev-slack-tenant.ts",
    "seed-platform-owner": "tsx scripts/seed-platform-owner.ts",
    "dev:e2e": "tsx scripts/dev-e2e.ts",
    "verify:e2e": "tsx scripts/verify-e2e.ts",
    "fly:setup": "tsx scripts/fly-setup.ts",
    "fly:image": "docker buildx build --platform linux/amd64 --tag registry.fly.io/ai-employee-workers:latest --push .",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test:db:setup": "PGPASSWORD=postgres psql -h localhost -p 54322 -U postgres -tc \"SELECT 1 FROM pg_database WHERE datname='ai_employee_test'\" | grep -q 1 && echo 'ai_employee_test already exists' || PGPASSWORD=postgres psql -h localhost -p 54322 -U postgres -c 'CREATE DATABASE ai_employee_test'",
    "db:studio": "prisma studio",
    "migrate:feedback": "tsx scripts/migrate-feedback-data.ts",
    "setup:two-tenants": "tsx scripts/setup-two-tenants.ts",
    "verify:multi-tenancy": "tsx scripts/verify-multi-tenancy.ts",
    "docker:start": "bash scripts/ensure-infra.sh",
    "docker:stop": "docker compose -f docker/supabase-services.yml down",
    "docker:reset": "bash scripts/docker-reset.sh",
    "docker:status": "docker ps --filter network=supabase-shared --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --no-warn-ignored"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@composio/core": "0.10.0",
    "@opencode-ai/sdk": "^1.3.3",
    "@prisma/client": "^6.0.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^173.0.0",
    "http-proxy-middleware": "^4.0.0",
    "inngest": "^4.1.0",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "resend": "^6.12.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@inngest/test": "^1.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "zx": "^8.8.5"
  }
}
