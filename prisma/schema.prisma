// This is your Prisma schema file
// AI Employee Platform — Phase 1 Foundation
// Source of truth: docs/2026-03-22-2317-ai-employee-architecture.md §13

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

// ============================================================
// 7 MVP-Active Tables
// ============================================================

model Task {
  id                 String    @id @default(uuid()) @db.Uuid
  archetype_id       String?   @db.Uuid
  project_id         String?   @db.Uuid
  external_id        String?
  source_system      String?
  status             String    @default("Received")
  requirements       Json?
  scope_estimate     Int?
  affected_resources Json?
  tenant_id          String    @db.Uuid
  raw_event          Json?
  dispatch_attempts  Int       @default(0)
  failure_reason     String?
  triage_result      Json?
  metadata           Json?
  planContent        String?   @map("plan_content") @db.Text
  planGeneratedAt    DateTime? @map("plan_generated_at")
  costUsdCents       Int       @default(0) @map("cost_usd_cents")
  started_at         DateTime?
  completed_at       DateTime?
  failure_code       String?
  compiled_agents_md String?   @db.Text
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  // Relations
  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  archetype      Archetype?      @relation(fields: [archetype_id], references: [id])
  project        Project?        @relation(fields: [project_id], references: [id])
  executions     Execution[]
  statusLogs     TaskStatusLog[]
  feedbackEvents FeedbackEvent[]
  taskMetric     TaskMetric?

  @@unique([external_id, source_system, tenant_id])
  @@index([archetype_id])
  @@index([tenant_id])
  @@map("tasks")
}

model Execution {
  id                 String    @id @default(uuid()) @db.Uuid
  task_id            String    @db.Uuid
  runtime_type       String?
  phase              String    @default("execution")
  runtime_id         String?
  fix_iterations     Int       @default(0)
  status             String    @default("pending")
  agent_version_id   String?   @db.Uuid
  prompt_tokens      Int       @default(0)
  completion_tokens  Int       @default(0)
  primary_model_id   String?
  estimated_cost_usd Decimal   @default(0) @db.Decimal(10, 4)
  heartbeat_at       DateTime?
  current_stage      String?
  waveNumber         Int?      @map("wave_number")
  waveState          Json?     @map("wave_state")
  session_transcript Json?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  // Relations
  task         Task          @relation(fields: [task_id], references: [id])
  agentVersion AgentVersion? @relation(fields: [agent_version_id], references: [id])
  deliverables Deliverable[]

  @@index([task_id])
  @@map("executions")
}

model Deliverable {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  execution_id  String   @db.Uuid
  delivery_type String
  external_ref  String?
  risk_score    Int      @default(0)
  status        String   @default("pending")
  content       String?  @db.Text
  metadata      Json?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  execution Execution @relation(fields: [execution_id], references: [id])

  @@index([execution_id])
  @@map("deliverables")
}

model Project {
  id                String   @id @default(uuid()) @db.Uuid
  department_id     String?  @db.Uuid
  name              String
  repo_url          String
  default_branch    String   @default("main")
  concurrency_limit Int      @default(3)
  tooling_config    Json?
  jira_project_key  String?
  tenant_id         String   @db.Uuid
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  tenant     Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [department_id], references: [id])
  tasks      Task[]

  @@unique([jira_project_key, tenant_id])
  @@map("projects")
}

model TaskStatusLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id     String   @db.Uuid
  from_status String?
  to_status   String
  actor       String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations — CHECK constraint enforced via raw SQL migration (Task 5)
  task Task @relation(fields: [task_id], references: [id])

  @@index([task_id])
  @@map("task_status_log")
}

// ============================================================
// 9 Forward-Compatibility Tables (empty but schema-ready)
// Populated when their corresponding milestones are built
// ============================================================

model Department {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  slack_channel String?
  tenant_id     String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  tenant     Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  archetypes Archetype[]
  projects   Project[]

  @@map("departments")
}

model Archetype {
  id                                String    @id @default(uuid()) @db.Uuid
  department_id                     String?   @db.Uuid
  role_name                         String?
  runtime                           String?
  trigger_sources                   Json?
  tool_registry                     Json?
  risk_model                        Json?
  concurrency_limit                 Int       @default(3)
  agent_version_id                  String?   @db.Uuid
  tenant_id                         String    @db.Uuid
  created_at                        DateTime  @default(now())
  updated_at                        DateTime  @updatedAt
  execution_instructions            String?   @db.Text
  delivery_instructions             String?   @db.Text
  notification_channel              String?   @db.Text
  vm_size                           String? // Per-archetype VM size override (e.g. 'shared-cpu-1x', 'shared-cpu-2x')
  enrichment_adapter                String? // Name of enrichment adapter to use (e.g. 'hostfully', null for none)
  pre_check_adapter                 String?
  worker_env                        Json?
  input_schema                      Json?
  model                             String
  deliverable_type                  String?
  status                            String    @default("active")
  overview                          Json?
  parent_draft_id                   String?
  deleted_at                        DateTime?
  estimated_manual_minutes          Int?
  estimated_manual_minutes_override Int?
  identity                          String?   @db.Text
  execution_steps                   String?   @db.Text
  delivery_steps                    String?   @db.Text
  temperature                       Float?    @default(1.0)
  platform_rules_override           String?   @db.Text // When set, replaces the default platform rules section in compiled AGENTS.md

  // Relations
  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  department     Department?     @relation(fields: [department_id], references: [id])
  agentVersion   AgentVersion?   @relation("CurrentArchetypeVersion", fields: [agent_version_id], references: [id])
  tasks          Task[]
  knowledgeBases KnowledgeBase[]
  riskModels     RiskModel[]
  agentVersions  AgentVersion[]  @relation("ArchetypeVersions")
  feedbackEvents FeedbackEvent[]
  employeeRules  EmployeeRule[]
  taskMetrics    TaskMetric[]

  @@map("archetypes")
}

model KnowledgeBase {
  id            String    @id @default(uuid()) @db.Uuid
  archetype_id  String?   @db.Uuid
  last_indexed  DateTime?
  chunk_count   Int       @default(0)
  source_config Json?
  tenant_id     String    @db.Uuid
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Relations
  tenant    Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  archetype Archetype? @relation(fields: [archetype_id], references: [id])

  @@map("knowledge_bases")
}

model KnowledgeBaseEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  entity_type String?
  entity_id   String?
  scope       String
  content     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, entity_type, entity_id, scope])
  @@index([tenant_id, entity_type, entity_id])
  @@map("knowledge_base_entries")
}

model RiskModel {
  id                     String   @id @default(uuid()) @db.Uuid
  archetype_id           String?  @db.Uuid
  factors                Json?
  auto_approve_threshold Int      @default(70)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  // Relations
  archetype Archetype? @relation(fields: [archetype_id], references: [id])

  @@map("risk_models")
}

model AgentVersion {
  id               String   @id @default(uuid()) @db.Uuid
  archetype_id     String?  @db.Uuid
  prompt_hash      String?
  model_id         String?
  tool_config_hash String?
  changelog_note   String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  is_active        Boolean  @default(true)

  // Relations
  archetype        Archetype?  @relation("ArchetypeVersions", fields: [archetype_id], references: [id])
  activeArchetypes Archetype[] @relation("CurrentArchetypeVersion")
  executions       Execution[]

  @@map("agent_versions")
}

// ============================================================
// Multi-Tenancy Tables
// ============================================================

model Tenant {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  slug       String
  config     Json?
  status     String    @default("active")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  secrets              TenantSecret[]
  tasks                Task[]
  projects             Project[]
  departments          Department[]
  archetypes           Archetype[]
  knowledgeBases       KnowledgeBase[]
  knowledgeBaseEntries KnowledgeBaseEntry[]
  integrations         TenantIntegration[]
  systemEvents         SystemEvent[]
  pendingApprovals     PendingApproval[]
  propertyLocks        PropertyLock[]
  feedbackEvents       FeedbackEvent[]
  employeeRules        EmployeeRule[]
  taskMetrics          TaskMetric[]
  memberships          TenantMembership[]
  invitations          TenantInvitation[]

  @@map("tenants")
}

model TenantIntegration {
  id          String    @id @default(uuid()) @db.Uuid
  tenant_id   String    @db.Uuid
  provider    String
  external_id String
  config      Json?
  status      String    @default("active")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, provider])
  @@map("tenant_integrations")
}

model SystemEvent {
  id                String   @id @default(uuid()) @db.Uuid
  task_id           String
  tenant_id         String   @db.Uuid
  tool_name         String
  issue_description String   @db.Text
  patch_applied     Boolean  @default(false)
  patch_diff        String?  @db.Text
  created_at        DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@map("system_events")
}

model TenantSecret {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  key        String
  ciphertext String
  iv         String
  auth_tag   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, key])
  @@map("tenant_secrets")
}

model PendingApproval {
  id               String    @id @default(uuid()) @db.Uuid
  tenant_id        String    @db.Uuid
  thread_uid       String
  task_id          String
  slack_ts         String
  channel_id       String
  created_at       DateTime  @default(now())
  reminder_sent_at DateTime? @map("reminder_sent_at")
  urgency          Boolean   @default(false) @map("urgency")
  recipient_name   String?   @map("recipient_name")
  context_label    String?   @map("context_label")
  deleted_at       DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, thread_uid])
  @@index([tenant_id])
  @@map("pending_approvals")
}

model PropertyLock {
  id                   String   @id @default(uuid()) @db.Uuid
  tenant_id            String   @db.Uuid
  property_external_id String
  lock_external_id     String
  lock_name            String
  lock_provider        String   @default("sifely")
  lock_role            String?
  property_type        String
  property_name        String
  passcode_name        String?
  lock_metadata        Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, property_external_id])
  @@map("property_locks")
}

// ============================================================
// Feedback System Redesign — New Tables
// ============================================================

model FeedbackEvent {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  archetype_id       String    @db.Uuid
  task_id            String?   @db.Uuid
  event_type         String
  actor_id           String?
  correction_content String?
  original_content   String?
  metadata           Json?
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?

  // Relations
  tenant    Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  archetype Archetype @relation(fields: [archetype_id], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [task_id], references: [id])

  @@index([tenant_id, archetype_id, created_at(sort: Desc)])
  @@map("feedback_events")
}

model EmployeeRule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  archetype_id    String    @db.Uuid
  rule_text       String
  source          String
  status          String
  source_task_id  String?   @db.Uuid
  parent_rule_ids String[]  @default([]) @db.Uuid
  slack_ts        String?
  slack_channel   String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  confirmed_at    DateTime? @db.Timestamptz(6)
  deleted_at      DateTime?

  // Relations
  tenant    Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  archetype Archetype @relation(fields: [archetype_id], references: [id], onDelete: Cascade)

  @@unique([source_task_id, source], name: "employee_rules_source_task_source_unique", map: "employee_rules_source_task_source_unique")
  @@index([tenant_id, archetype_id, status])
  @@index([status, archetype_id])
  @@map("employee_rules")
}

model ModelCatalog {
  id                           String    @id @default(uuid()) @db.Uuid
  model_id                     String // e.g. "minimax/minimax-m2.7"
  display_name                 String
  provider                     String
  description                  String?   @db.Text
  context_window               Int
  input_cost_per_million       Float
  output_cost_per_million      Float
  is_free                      Boolean   @default(false)
  throughput_tokens_per_sec    Float?
  latency_seconds              Float?
  tool_call_error_rate         Float?
  structured_output_error_rate Float?
  quality_index                Float?
  agentic_score                Float?
  tool_use_score               Float?
  instruction_following_score  Float?
  non_hallucination_rate       Float?
  supports_tools               Boolean   @default(false)
  supports_structured_output   Boolean   @default(false)
  is_active                    Boolean   @default(true)
  notes                        String?   @db.Text
  strengths                    String?   @db.Text
  weaknesses                   String?   @db.Text
  created_at                   DateTime  @default(now())
  updated_at                   DateTime  @updatedAt
  deleted_at                   DateTime?

  @@unique([model_id])
  @@map("model_catalog")
}

// ============================================================
// Platform Settings (global — not tenant-scoped)
// ============================================================

model PlatformSetting {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  value       String
  description String?
  is_required Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  @@map("platform_settings")
}

// ============================================================
// User Auth & RBAC
// ============================================================

enum Role {
  PLATFORM_OWNER
  ADMIN
  EDITOR
  USER
  VIEWER
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  supabase_id       String?            @unique @db.Uuid
  email             String             @unique
  name              String?
  role              Role               @default(USER)
  status            String             @default("active")
  current_tenant_id String?            @db.Uuid
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @updatedAt @db.Timestamptz(6)
  deleted_at        DateTime?          @db.Timestamptz(6)
  memberships       TenantMembership[]
  invitations_sent  TenantInvitation[] @relation("InvitationInviter")

  @@index([deleted_at])
  @@map("users")
}

model TenantMembership {
  tenant_id  String     @db.Uuid
  user_id    String     @db.Uuid
  role       TenantRole @default(MEMBER)
  joined_at  DateTime   @default(now()) @db.Timestamptz(6)
  deleted_at DateTime?  @db.Timestamptz(6)
  tenant     Tenant     @relation(fields: [tenant_id], references: [id])
  user       User       @relation(fields: [user_id], references: [id])

  @@id([tenant_id, user_id])
  @@index([user_id])
  @@map("tenant_memberships")
}

model TenantInvitation {
  id          String     @id @default(uuid()) @db.Uuid
  tenant_id   String     @db.Uuid
  email       String
  role        TenantRole @default(MEMBER)
  token       String     @unique
  status      String     @default("pending")
  expires_at  DateTime   @db.Timestamptz(6)
  accepted_at DateTime?  @db.Timestamptz(6)
  declined_at DateTime?  @db.Timestamptz(6)
  revoked_at  DateTime?  @db.Timestamptz(6)
  inviter_id  String?    @db.Uuid
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  tenant      Tenant     @relation(fields: [tenant_id], references: [id])
  inviter     User?      @relation("InvitationInviter", fields: [inviter_id], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([email])
  @@index([tenant_id, email])
  @@map("tenant_invitations")
}

// ============================================================
// Time Estimation & Task Metrics
// ============================================================

model TaskMetric {
  id           String    @id @default(uuid()) @db.Uuid
  task_id      String    @unique @db.Uuid
  archetype_id String    @db.Uuid
  tenant_id    String    @db.Uuid
  work_minutes Int
  created_at   DateTime  @default(now())
  deleted_at   DateTime?

  task      Task      @relation(fields: [task_id], references: [id])
  archetype Archetype @relation(fields: [archetype_id], references: [id])
  tenant    Tenant    @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, archetype_id])
  @@map("task_metrics")
}

// ============================================================
// Composio Integration
// ============================================================

model ComposioConnection {
  id              String    @id @default(uuid())
  tenant_id       String
  toolkit         String
  status          String    @default("active")
  connected_at    DateTime  @default(now())
  disconnected_at DateTime?
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([tenant_id, toolkit])
  @@index([tenant_id])
  @@map("composio_connections")
}

model TaskComposioCall {
  id        String   @id @default(uuid())
  task_id   String
  tenant_id String
  toolkit   String
  tool_name String
  called_at DateTime @default(now())
  phase     String? // Values: 'execution' | 'delivery'

  @@index([task_id])
  @@index([tenant_id])
  @@map("task_composio_calls")
}
