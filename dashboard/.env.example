# Dashboard environment variables (baked in at build time by Vite — NOT available at runtime)
# For local dev, defaults are already in src/lib/constants.ts — only set these to override.
# For production (Render build), ALL must be set in the build environment.

VITE_POSTGREST_URL=http://localhost:54331/rest/v1
# Production: https://{supabase-ref}.supabase.co/rest/v1

VITE_SUPABASE_ANON_KEY=
# Production: Supabase project anon key (from Settings → API)

VITE_GATEWAY_URL=http://localhost:7700
# Production: https://{render-service}.onrender.com

VITE_INNGEST_URL=http://localhost:8288
# Production: https://inn.gs (Inngest Cloud ingest endpoint)
