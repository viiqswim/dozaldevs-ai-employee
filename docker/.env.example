############
# URLs
############

# Access to Dashboard and REST API (mapped to 54321 in docker-compose.yml)
SUPABASE_PUBLIC_URL=http://localhost:54321

# Full external URL of the Auth service
API_EXTERNAL_URL=http://localhost:54321


############
# Database - Postgres configuration
############

POSTGRES_HOST=db
# POSTGRES_DB must stay as ai_employee.
# The Supabase CLI (supabase start) hardcodes the database name as "postgres" in
# its Go source and cannot be overridden via config. PostgREST (which worker
# containers use to read/write task data) would therefore always connect to
# "postgres" — so switching only DATABASE_URL to ai_employee would create a
# split-brain: Prisma writes to ai_employee, PostgREST reads from postgres.
# This self-hosted Docker Compose uses ${POSTGRES_DB} everywhere, so all
# services (including PostgREST) natively use ai_employee from the start.
POSTGRES_DB=ai_employee
POSTGRES_PORT=5432


############
# Supavisor - Database pooler
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=your-tenant-id
POOLER_DB_POOL_SIZE=5


############
# Studio - Configuration for the Dashboard
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=sk-proj-xxxxxxxx


############
# Auth - Configuration for the authentication server
############

SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true


############
# Storage - Configuration for Storage
############

GLOBAL_S3_BUCKET=stub
REGION=stub
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=secret1234
STORAGE_TENANT_ID=stub


############
# Functions - Configuration for Edge functions
############

FUNCTIONS_VERIFY_JWT=false


############
# API - Configuration for PostgREST
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public


############
# Analytics - Configuration for Logflare
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER


############
# API gateway
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=


############
# imgproxy
############

IMGPROXY_AUTO_WEBP=true
