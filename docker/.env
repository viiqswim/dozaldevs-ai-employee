# ai-employee Docker Supabase Services Configuration
# Used by: docker compose -f docker/supabase-services.yml --env-file docker/.env up -d
# Or:      bash scripts/ensure-infra.sh (recommended)
#
# This file configures the per-project services (Auth + Kong + PostgREST).
# Shared infrastructure (PostgreSQL, Mailpit, Redis) is in docker/shared-infra.yml.

POSTGRES_HOST=shared-postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
DB_NAME=ai_employee

KONG_PORT=54331
AUTH_PORT=9002

JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Keys generated from JWT_SECRET above (same secret = same keys across projects)
# Regenerate with: bash scripts/generate-jwt-keys.sh
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc2NzkzNDI4LCJleHAiOjIwOTIxNTM0Mjh9.ggG1F3fTf2dIZbDADkvdrFz5BPJ6vqBax3k7sEFZFgs
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3NzY3OTM0MjgsImV4cCI6MjA5MjE1MzQyOH0.AV3qUQYBeohpMUMXSL4Tm9wJsXtL6MKfGqJJab3Gr4I

SITE_URL=http://localhost:3000
SMTP_HOST=shared-mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@ai-employee.local
SMTP_SENDER_NAME=AI Employee

DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ADDITIONAL_REDIRECT_URLS=

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# PostgREST (workers use this for task data access)
PGRST_DB_SCHEMAS=public,storage
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public
