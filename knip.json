{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/gateway/server.ts",
    "src/workers/opencode-harness.mts",
    "src/worker-tools/**/*.ts",
    "scripts/*.ts",
    "scripts/**/*.ts",
    "src/lib/enrichment-adapters/hostfully.ts",
    "src/lib/enrichment-adapters/index.ts"
  ],
  "project": ["src/**/*.{ts,mts}", "scripts/**/*.ts"],
  "ignore": [
    "dashboard/**",
    "src/inngest/triggers/guest-message-poll.ts",
    "src/lib/github-client.ts",
    "src/lib/model-selection/index.ts"
  ],
  "ignoreDependencies": ["googleapis"],
  "ignoreBinaries": ["psql", "supabase", "which", "cloudflared", "gh", "pg_isready"]
}
