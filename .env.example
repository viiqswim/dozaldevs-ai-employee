# =============================================================================
# Database
# =============================================================================
# Required: PostgreSQL connection via Prisma (use ai_employee DB)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/ai_employee"
# Port must match POSTGRES_PORT_HOST in docker/.env (default: 54322)
# Required: Direct connection for migrations (same as DATABASE_URL for local)
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:54322/ai_employee"

# =============================================================================
# Supabase (PostgREST + Auth)
# =============================================================================
# Required: Supabase PostgREST base URL
SUPABASE_URL="http://localhost:54321"
# Port must match KONG_HTTP_PORT_HOST in docker/.env (default: 54321)
# Required: Supabase service role key (from `supabase status`)
SUPABASE_SECRET_KEY="your-supabase-service-role-key"

# =============================================================================
# Encryption
# =============================================================================
# Required: 32-byte master key for AES-256-GCM secret encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=""

# =============================================================================
# Webhooks & Admin
# =============================================================================
# Required: HMAC secret for Jira webhook validation
JIRA_WEBHOOK_SECRET="test-secret"
# Optional: HMAC secret for GitHub webhook validation
GITHUB_WEBHOOK_SECRET=""
# Admin API key for all /admin/* endpoints including manual trigger (generate with: openssl rand -hex 32)
ADMIN_API_KEY=""

# =============================================================================
# Inngest (Event Queue)
# =============================================================================
# Required: Set to "1" for local Inngest Dev Server (port 8288)
INNGEST_DEV="1"
# Required: Inngest event key (use "local" for dev)
INNGEST_EVENT_KEY="local"
# Optional: Inngest signing key (not required for local dev)
INNGEST_SIGNING_KEY=""
# Optional: Override Inngest server URL (defaults to http://localhost:8288)
INNGEST_BASE_URL="http://localhost:8288"

# =============================================================================
# Execution (Worker Container)
# =============================================================================
# Required: OpenRouter API key for AI code generation
OPENROUTER_API_KEY="your-openrouter-api-key"
# Optional: Model to use via OpenRouter (defaults to minimax/minimax-m2.7)
OPENROUTER_MODEL="minimax/minimax-m2.7"
# Leave empty to disable the plan judge gate
PLAN_VERIFIER_MODEL=anthropic/claude-haiku-4-5
# Optional: Code generation timeout in minutes (default: 60, increase for complex tasks)
# ORCHESTRATE_TIMEOUT_MINS=60
# Required: GitHub token for git push + PR creation
GITHUB_TOKEN="your-github-personal-access-token"

# =============================================================================
# Local Development Mode
# =============================================================================
# Optional: Set to "1" to use local Docker instead of Fly.io for worker containers
# DO NOT add to .env permanently — set as env prefix: USE_LOCAL_DOCKER=1 pnpm dev
USE_LOCAL_DOCKER=""

# =============================================================================
# Hybrid Fly.io Worker Mode (USE_FLY_HYBRID=1)
# =============================================================================
# Optional: Set to "1" to dispatch workers to real Fly.io machines while keeping Supabase/Inngest local
# Mutually exclusive with USE_LOCAL_DOCKER (local Docker takes precedence if both set)
USE_FLY_HYBRID=""
# Optional: Max number of 30-second polls for hybrid mode completion (default: 120 = 60 minutes)
# Increase for very long-running tasks
FLY_HYBRID_POLL_MAX="120"
# Required for hybrid mode (USE_FLY_HYBRID=1): public HTTPS URL for local Supabase.
# Start Cloudflare Tunnel: cloudflared tunnel --url http://localhost:54321
# Set TUNNEL_URL to the https://xxx.trycloudflare.com URL printed by cloudflared.
# Note: ngrok free tier does not work with Fly.io (see AGENTS.md §6).
TUNNEL_URL=""

# =============================================================================
# Fly.io (Production / Cloud Deployment — Phase 9)
# =============================================================================
# Optional: Required only for cloud deployment (not needed for local dev)
FLY_API_TOKEN="your-fly-api-token"
# Optional: Fly.io app name for worker machines
FLY_WORKER_APP="ai-employee-workers"
# Optional: Docker image URI for worker machines (default: registry.fly.io/ai-employee-workers:latest)
FLY_WORKER_IMAGE="registry.fly.io/ai-employee-workers:latest"

# =============================================================================
# External Integrations (Optional for local dev)
# =============================================================================
JIRA_API_TOKEN="your-jira-api-token"
JIRA_BASE_URL="https://your-domain.atlassian.net"
JIRA_USER_EMAIL="your-email@example.com"
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
# DEPRECATED: migrated per-tenant via scripts/setup-two-tenants.ts. Safe to remove after VLRE migration.

# Slack OAuth app credentials (for per-workspace OAuth installs)
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
# Base URL for OAuth redirect (e.g. https://your-domain.com or http://localhost:3000 for local dev)
SLACK_REDIRECT_BASE_URL="http://localhost:3000"
SLACK_CHANNEL_ID="C0123456789"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/your-slack-webhook"

# =============================================================================
# Cost Control
# =============================================================================
# Optional: Daily cost cap per department (default: 50)
COST_LIMIT_USD_PER_DEPT_PER_DAY="50"
# Required: Agent version ID for execution tracking
AGENT_VERSION_ID="00000000-0000-0000-0000-000000000002"

# =============================================================================
# Summarizer AI Employee (Papi Chulo — Daily Slack Digest)
# =============================================================================
# Required for verifying Slack interaction webhooks (HMAC-SHA256)
# Get from: Slack app settings → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=""

# Comma-separated Slack channel IDs to summarize (e.g. "C123,C456,C789")
# Slack bot must have channels:history scope for each channel
DAILY_SUMMARY_CHANNELS=""

# Channel ID where summaries are posted for approval
SUMMARY_TARGET_CHANNEL=""

# Fly.io app name for summarizer machines (separate from engineering workers)
FLY_SUMMARIZER_APP="ai-employee-summarizer"

# VM size for summarizer machines (much smaller than engineering's performance-2x)
SUMMARIZER_VM_SIZE="shared-cpu-1x"
