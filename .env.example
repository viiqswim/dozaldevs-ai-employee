# =============================================================================
# Database
# =============================================================================
# Required: PostgreSQL connection via Prisma (use ai_employee DB)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/ai_employee"
# Required: Direct connection for migrations (same as DATABASE_URL for local)
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:54322/ai_employee"

# =============================================================================
# Supabase (PostgREST + Auth)
# =============================================================================
# Required: Supabase PostgREST base URL
SUPABASE_URL="http://localhost:54321"
# Required: Supabase service role key (from `supabase status`)
SUPABASE_SECRET_KEY="your-supabase-service-role-key"

# =============================================================================
# Webhooks
# =============================================================================
# Required: HMAC secret for Jira webhook validation
JIRA_WEBHOOK_SECRET="test-secret"
# Optional: HMAC secret for GitHub webhook validation
GITHUB_WEBHOOK_SECRET=""

# =============================================================================
# Inngest (Event Queue)
# =============================================================================
# Required: Set to "1" for local Inngest Dev Server (port 8288)
INNGEST_DEV="1"
# Required: Inngest event key (use "local" for dev)
INNGEST_EVENT_KEY="local"
# Optional: Inngest signing key (not required for local dev)
INNGEST_SIGNING_KEY=""
# Optional: Override Inngest server URL (defaults to http://localhost:8288)
INNGEST_BASE_URL="http://localhost:8288"

# =============================================================================
# Execution (Worker Container)
# =============================================================================
# Required: OpenRouter API key for AI code generation
OPENROUTER_API_KEY="your-openrouter-api-key"
# Optional: Model to use via OpenRouter (defaults to minimax/minimax-m2.7)
OPENROUTER_MODEL="minimax/minimax-m2.7"
# Required: GitHub token for git push + PR creation
GITHUB_TOKEN="your-github-personal-access-token"

# =============================================================================
# Local Development Mode
# =============================================================================
# Optional: Set to "1" to use local Docker instead of Fly.io for worker containers
# DO NOT add to .env permanently — set as env prefix: USE_LOCAL_DOCKER=1 pnpm dev
USE_LOCAL_DOCKER=""

# =============================================================================
# Fly.io (Production / Cloud Deployment — Phase 9)
# =============================================================================
# Optional: Required only for cloud deployment (not needed for local dev)
FLY_API_TOKEN="your-fly-api-token"
# Optional: Fly.io app name for worker machines
FLY_WORKER_APP="ai-employee-workers"

# =============================================================================
# External Integrations (Optional for local dev)
# =============================================================================
JIRA_API_TOKEN="your-jira-api-token"
JIRA_BASE_URL="https://your-domain.atlassian.net"
JIRA_USER_EMAIL="your-email@example.com"
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
SLACK_CHANNEL_ID="C0123456789"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/your-slack-webhook"

# =============================================================================
# Cost Control
# =============================================================================
# Optional: Daily cost cap per department (default: 50)
COST_LIMIT_USD_PER_DEPT_PER_DAY="50"
# Required: Agent version ID for execution tracking
AGENT_VERSION_ID="00000000-0000-0000-0000-000000000002"
