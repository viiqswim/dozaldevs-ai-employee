# =============================================================================
# Database
# =============================================================================
# Prisma ORM connection string — must use the ai_employee database, NOT postgres.
# Port must match POSTGRES_PORT_HOST in docker/.env (default: 54322).
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/ai_employee"
# Direct connection for Prisma migrations (bypasses connection pooling — same as DATABASE_URL for local dev).
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:54322/ai_employee"

# =============================================================================
# Supabase (PostgREST + Auth)
# =============================================================================
# IMPORTANT — values must match one of the two profiles below. Mixing LOCAL and
# CLOUD values causes a fatal error at gateway startup (assertEnvProfile()).
#
# ── LOCAL profile (default for local dev) ────────────────────────────────────
# PostgREST base URL — port must match KONG_HTTP_PORT_HOST in docker/.env (default: 54331).
#   SUPABASE_URL="http://localhost:54331"
# Service role JWT — copy SERVICE_ROLE_KEY from docker/.env.
#   SUPABASE_SECRET_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Anon JWT — copy ANON_KEY from docker/.env.
#   SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
#
# ── CLOUD profile (Supabase Cloud project) ───────────────────────────────────
# Project API URL — found in Supabase Cloud → Settings → API → Project URL.
#   SUPABASE_URL="https://<project-ref>.supabase.co"
# Service role key — found in Supabase Cloud → Settings → API → service_role key.
#   SUPABASE_SECRET_KEY="sb_secret_<your-cloud-secret-key>"
# Publishable (anon) key — found in Supabase Cloud → Settings → API → anon/public key.
#   SUPABASE_ANON_KEY="sb_publishable_<your-cloud-publishable-key>"
#
# ─────────────────────────────────────────────────────────────────────────────
# Active values (LOCAL profile):
SUPABASE_URL="http://localhost:54331"
# Service role JWT — copy the value of SERVICE_ROLE_KEY from docker/.env.
# pnpm setup auto-creates docker/.env from docker/.env.example; the default demo key is already there.
SUPABASE_SECRET_KEY="your-supabase-service-role-key"
# Anon JWT — copy the value of ANON_KEY from docker/.env.
# pnpm setup auto-creates docker/.env from docker/.env.example; the default demo key is already there.
SUPABASE_ANON_KEY="your-supabase-anon-key"

# =============================================================================
# Platform Core
# =============================================================================
# 32-byte master key for AES-256-GCM encryption of all tenant secrets in the database.
# Generate: openssl rand -hex 32
# WARNING: Changing this key requires re-encrypting all existing tenant secrets.
ENCRYPTION_KEY=""
# Hex key for all /admin/* endpoints. Auto-generated by pnpm setup.
ADMIN_API_KEY=""
# Machine-to-machine auth token for scripts, crons, and Inngest functions.
# Replaces ADMIN_API_KEY for machine callers. Never expose to browser or /api/config.js.
# Generate with: openssl rand -hex 32
SERVICE_TOKEN=""
# Gateway HTTP port.
PORT=7700
# Public HTTPS URL of this gateway (e.g. https://your-app.onrender.com). Required for Inngest Cloud callbacks in production. Leave empty for local dev.
GATEWAY_PUBLIC_URL=

# =============================================================================
# Inngest (Event Queue)
# =============================================================================
# Set to "1" to point at the local Inngest Dev Server (http://localhost:8288).
INNGEST_DEV="1"
# Event key — use "local" for dev; must match the Inngest dashboard key in production.
INNGEST_EVENT_KEY="local"
# Signing key — not required for local dev; required in production.
INNGEST_SIGNING_KEY=""
# Override Inngest server URL (defaults to http://localhost:8288 when INNGEST_DEV=1).
# INNGEST_BASE_URL="http://localhost:8288"

# =============================================================================
# Worker Dispatch Mode
# =============================================================================
# Controls where employee worker containers run.
# ''       (or unset) = local Docker containers (default, no tunnel needed)
# 'docker'            = explicit local Docker (same as empty)
# 'fly'               = Fly.io machines (requires TUNNEL_URL and FLY_API_TOKEN)
WORKER_RUNTIME=""

# PostgREST tunnel URL for Fly.io workers to reach local Supabase (port 54331).
# Named tunnel (stable — survives restarts): https://postgrest-ai-employee.dozaldevs.com
# Quick tunnel (changes every restart): run "cloudflared tunnel --url http://localhost:54331"
# Leave empty when WORKER_RUNTIME is 'docker' or unset.
TUNNEL_URL=""

# Public URL of the gateway, injected into worker containers so tools can call
# back to internal endpoints (e.g. /internal/tasks/:id/google-token).
# Local Docker: leave empty — lifecycle injects host.docker.internal:7700 automatically.
# Production (Fly.io workers): set to the public gateway URL (e.g. https://ai-employees-laaa.onrender.com).
GATEWAY_URL=""

# =============================================================================
# Render (Production Gateway)
# =============================================================================
# API key for the Render dashboard — used by agents to check deploy status and fetch logs.
# Get from: https://dashboard.render.com/u/settings → API Keys
RENDER_API_KEY=""
# Service ID for the ai-employees gateway web service on Render.
# Find it in the Render dashboard URL: dashboard.render.com/web/<SERVICE_ID>
RENDER_SERVICE_ID=""

# =============================================================================
# Fly.io (Worker Runtime)
# =============================================================================
# Required only when WORKER_RUNTIME=fly. Not needed for local Docker mode.
FLY_API_TOKEN=""
# Fly.io app name for all employee worker machines.
FLY_WORKER_APP="ai-employee-workers"
# Docker image URI pushed to the Fly.io registry for worker machines.
FLY_WORKER_IMAGE="registry.fly.io/ai-employee-workers:latest"

# =============================================================================
# AI / LLM Providers
# =============================================================================
# Primary API key for all employee AI calls routed through OpenRouter.
OPENROUTER_API_KEY=""
# OpenCodeGo — $10/mo flat subscription for open source models
# Get your key at https://opencode.ai/auth — subscribe to Go plan
# Optional locally and in CI (calls fall back to OpenRouter when unset).
# REQUIRED in production: the gateway refuses to boot if NODE_ENV=production and this is missing.
# When set, the worker harness automatically routes compatible models (MiniMax, DeepSeek, MiMo, etc.)
# through OpenCodeGo instead of OpenRouter. Remove this var locally to revert all routing to OpenRouter.
OPENCODE_GO_API_KEY=
# Default model for worker execution.
# APPROVED MODELS ONLY — see AGENTS.md "Approved LLM Models" (any other model is a bug):
#   minimax/minimax-m2.7       — primary execution model (all employee work)
#   anthropic/claude-haiku-4-5 — verification/judge only (plan verification, intent classification)
# For local E2E testing, override to deepseek/deepseek-v4-flash — confirmed reliable for tool calling.
# Some catalog models (e.g. minimax/minimax-m2.7) may not call bash tools, causing immediate task failure.
OPENROUTER_MODEL="minimax/minimax-m2.7"
# Model used for the plan verification gate. Set to anthropic/claude-haiku-4-5, or leave empty to disable.
PLAN_VERIFIER_MODEL="anthropic/claude-haiku-4-5"

# =============================================================================
# GitHub App (Engineer Employee)
# =============================================================================
# GitHub App numeric ID — found on the GitHub App settings page (Settings → Developer settings → GitHub Apps → your app).
# Per-environment: dev and prod use different App IDs.
# Dev: dozaldevs-ai-employee-dev App ID  |  Prod: dozaldevs-ai-employee App ID
GITHUB_APP_ID="your-app-id"
# GitHub App URL slug — used in the install redirect URL (https://github.com/apps/<GITHUB_APP_NAME>/installations/new).
# Per-environment: dev and prod use different App slugs.
# Dev: dozaldevs-ai-employee-dev  |  Prod: dozaldevs-ai-employee
GITHUB_APP_NAME="your-app-name"
# RSA private key for the GitHub App (PEM format). Newlines must be encoded as \n when stored as a single-line env var.
# Generate from: GitHub App settings → Private keys → Generate a private key
# Per-environment: each App has its own private key — never share between dev and prod.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key\n-----END RSA PRIVATE KEY-----"
# HMAC secret for GitHub webhook validation. REQUIRED — if unset, the webhook endpoint
# returns 401 and rejects ALL payloads, silently breaking installation cleanup.
# Per-environment: generate a unique secret per App (never share between dev and prod).
GITHUB_WEBHOOK_SECRET=""

# =============================================================================
# Google Integration
# =============================================================================
GOOGLE_CLIENT_ID=           # OAuth 2.0 client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=       # OAuth 2.0 client secret from Google Cloud Console
GOOGLE_REDIRECT_BASE_URL=http://localhost:7700   # Base URL for OAuth callback (production: https://your-domain.com)

# =============================================================================
# Slack Integration
# =============================================================================
# HMAC-SHA256 signing secret — verifies incoming Slack interaction webhook payloads.
# Get from: api.slack.com → Your App → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=""

# Bot OAuth token for Slack API calls (postMessage, chat.update, reactions, etc.).
# Get from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
# Note: This is the primary bot token (VLRE workspace by default).
#       DozalDevs bot token is stored as a tenant_secret — not here.
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"

# Per-developer xapp- token for Socket Mode — opens the Bolt WebSocket connection for interactive button clicks.
# Without this, Slack approval buttons will not reach the gateway.
# Each developer must use their OWN dev app token — NEVER share the prod token locally.
# Slack round-robins events per-app across all open sockets, so a shared token drops ~50% of @mentions.
# See docs/guides/*-slack-per-dev-app-onboarding.md for how to create your personal dev app.
# Get from: api.slack.com → Your App → Basic Information → App-Level Tokens → generate with connections:write scope
SLACK_APP_TOKEN="xapp-your-app-level-token"

# OAuth app credentials — required for per-workspace Slack OAuth installs.
# Get from: api.slack.com → Your App → Basic Information → App Credentials
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Public base URL for Slack OAuth redirect. Must be pre-registered in the Slack app's Redirect URLs.
# Use the stable named Cloudflare Tunnel (never changes on restart): https://local-ai-employee.dozaldevs.com
# Each contributor needs their own subdomain registered in the Slack app Redirect URLs.
SLACK_REDIRECT_BASE_URL="https://local-ai-employee.dozaldevs.com"

# Default fallback channel ID used by the interaction-handler when no archetype-specific channel is set.
SLACK_CHANNEL_ID="C0123456789"

# Per-tenant Slack bot token — used ONLY by prisma/seed.ts to seed tenant_secrets on DB reset.
# This is the only per-tenant token that belongs in .env (all others are provisioned via admin API).
# Get from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token (VLRE workspace)
VLRE_SLACK_BOT_TOKEN="xoxb-your-vlre-bot-token"

# =============================================================================
# Notion OAuth
# =============================================================================
NOTION_CLIENT_ID=           # From Notion Developer Portal → Your Integration → OAuth
NOTION_CLIENT_SECRET=       # From Notion Developer Portal → Your Integration → OAuth
NOTION_REDIRECT_BASE_URL=   # e.g., https://local-ai-employee.dozaldevs.com (must be HTTPS for Notion OAuth)

# =============================================================================
# Webhooks
# =============================================================================
# HMAC secret for Jira webhook validation (Engineering employee — deprecated/on hold).
JIRA_WEBHOOK_SECRET="test-secret"
# Jira OAuth 2.0 — required for the Connect Jira flow in the dashboard.
# Create an OAuth app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""
# Base URL used to construct the OAuth redirect_uri. Defaults to http://localhost:7700.
# In production / tunnel mode, set to your public gateway URL.
JIRA_REDIRECT_BASE_URL=""
# Set to "true" to use mock fixtures instead of real Jira API calls (for local dev/testing).
JIRA_MOCK=""
# Public URL for one-time Hostfully webhook registration via the admin API.
# This is the ONLY Hostfully-related value that belongs in .env (global dev config, not per-tenant).
# Use the stable named Cloudflare Tunnel: https://local-ai-employee.dozaldevs.com
WEBHOOK_PUBLIC_URL=""

# =============================================================================
# Telegram (Developer Notifications)
# =============================================================================
# Push notifications for Prometheus/Atlas plan lifecycle events (plan ready, plan complete).
# Get token: message @BotFather on Telegram → /newbot
# Get chat ID: message your bot → GET https://api.telegram.org/bot<TOKEN>/getUpdates → look for "chat":{"id":...}
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# =============================================================================
# Cost Control
# =============================================================================
# Agent version ID for execution tracking (seeded in prisma/seed.ts).
AGENT_VERSION_ID="00000000-0000-0000-0000-000000000002"

# =============================================================================
# TENANT SECRETS — DO NOT SET HERE
# =============================================================================
# The following credentials are stored per-tenant via the admin API (tenant_secrets table),
# NOT as .env variables. loadTenantEnv() auto-injects them as uppercase env vars into each
# worker machine. Never put real values for these in .env.
#
# Hostfully (VLRE tenant):
#   hostfully_api_key    → injected as HOSTFULLY_API_KEY
#   hostfully_agency_uid → injected as HOSTFULLY_AGENCY_UID
#   hostfully_mock       → injected as HOSTFULLY_MOCK for worker containers (disables live API calls)
#   Note: HOSTFULLY_MOCK is also read by the gateway's guest-message-poll cron. Set it as a
#   global .env var (HOSTFULLY_MOCK=true) only during local E2E testing with mock fixtures.
#
# Sifely Smart Lock (VLRE tenant):
#   sifely_client_id   → injected as SIFELY_CLIENT_ID (value: "VLRE")
#   sifely_username    → injected as SIFELY_USERNAME
#   sifely_password    → injected as SIFELY_PASSWORD (MD5 hash of the account password)
#   sifely_base_url    → injected as SIFELY_BASE_URL (https://app-smart-server.sifely.com)
#
# DozalDevs Slack bot token:
#   slack_bot_token (DozalDevs) → stored as tenant_secrets for tenant 00000000-0000-0000-0000-000000000002
#
# Provisioning example:
#   curl -X PUT -H "X-Admin-Key: $ADMIN_API_KEY" -H "Content-Type: application/json" \
#     "http://localhost:7700/admin/tenants/<tenantId>/secrets/hostfully_api_key" \
#     -d '{"value":"<key>"}'

