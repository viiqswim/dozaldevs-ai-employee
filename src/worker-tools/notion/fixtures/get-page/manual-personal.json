    {
      "object": "block",
      "id": "370d540b-4380-8048-b1a9-efd21cd734f4",
      "type": "numbered_list_item",
      "has_children": false,
      "in_trash": false,
      "numbered_list_item": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Regla de Cobro (Check-In): El costo y tiempo de limpieza se calcula siempre en base a los CHECK-INs, no a los CHECK-OUTs. Ejemplos: Si un Home hace checkout y 4 Rooms hacen check-in, se cobran los 4 cuartos. Si 4 Rooms hacen checkout y un Home hace check-in, se cobra el Home. Si hay checkout sin check-in ese día, se cobra como cuartos (no como Home). El output debe indicar claramente qué hace CHECK-IN y qué hace CHECK-OUT para que el limpiador tenga contexto completo.",
              "link": null
            },
            "plain_text": "Regla de Cobro (Check-In): El costo y tiempo de limpieza se calcula siempre en base a los CHECK-INs, no a los CHECK-OUTs. Ejemplos: Si un Home hace checkout y 4 Rooms hacen check-in, se cobran los 4 cuartos. Si 4 Rooms hacen checkout y un Home hace check-in, se cobra el Home. Si hay checkout sin check-in ese día, se cobra como cuartos (no como Home). El output debe indicar claramente qué hace CHECK-IN y qué hace CHECK-OUT para que el limpiador tenga contexto completo.",
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            }
          }
